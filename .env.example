# Render command queue
XIAOKE_ACTIONS_BASE_URL=https://xiaoke-actions.onrender.com
STACKCHAN_DEVICE_TOKEN=
STACKCHAN_DEVICE_ID=stackchan-01
STACKCHAN_POLL_SECONDS=1.5
STACKCHAN_HEARTBEAT_SECONDS=30

# Local Stack Chan and this computer's LAN address
STACKCHAN_IP=
STACKCHAN_PORT=80
MAC_IP=
AUDIO_SERVE_PORT=5060

# Speech. edge-tts uses the network; Windows SAPI is the offline fallback.
TTS_ENGINE=edge
EDGE_TTS_BIN=edge-tts
STACKCHAN_AUDIO_MODE=wav
